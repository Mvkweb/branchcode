{
  "$schema": "https://raw.githubusercontent.com/nicehash/tauri-schema/v2/schema.json",
  "productName": "branchcode",
  "version": "0.1.0",
  "identifier": "com.branchcode.dev",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build"
  },
  "app": {
    "withGlobalTauri": false,
    "security": {
      "csp": null
    },
    "windows": [
      {
        "title": "Branchcode",
        "width": 1440,
        "height": 920,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "center": true,
        "minWidth": 800,
        "minHeight": 600
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDczNzM3OEJFMjY1NjY1OApSV1JZWm1YaWl6YzNCMGEvamJNZms4bkZZRGNMSEtYRDE4ZVNSQ3pqR3NyTEh5QnNOVXkyYk9tdAo=",
      "endpoints": ["https://branchcode.mvktest.workers.dev/"],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
